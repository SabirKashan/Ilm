# ─── Supabase ──────────────────────────────────────────────────────────────────
# Your Supabase project URL (safe to expose in frontend)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anon key (safe to expose in frontend — RLS is enforced)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Supabase service role key — NEVER expose in frontend or commit to git
# Used only in server-side routes to bypass RLS for admin operations
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ─── Cron job security ─────────────────────────────────────────────────────────
# Secret token used to authenticate Vercel cron calls to /api/cron/*
# Generate with: openssl rand -hex 32
# Must be set in Vercel environment variables → matches vercel.json cron auth header
CRON_SECRET=your-secret-here

# ─── App URL ───────────────────────────────────────────────────────────────────
# Full URL of your deployed app (no trailing slash)
# Used for generating absolute links in WhatsApp messages
NEXT_PUBLIC_APP_URL=https://ilm.school

# ─── WATI WhatsApp Business API ────────────────────────────────────────────────
# These are configured per-school in the database (schools.wati_endpoint, schools.wati_token)
# No global WATI keys needed — each school provides their own WATI credentials
# See: https://docs.wati.io for setup instructions
